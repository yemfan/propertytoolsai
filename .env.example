# Copy to `.env` at this repo root for Prisma CLI (migrate / generate uses this path by default).
# Use your Supabase **direct** Postgres URI (Settings → Database → Connection string → URI).
# For migrations, prefer the non-pooler host if Supabase documents it.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?schema=public"
