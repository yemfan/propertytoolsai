{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "../../.next/**",
        "!../../.next/cache/**",
        "dist/**"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    }
  }
}

