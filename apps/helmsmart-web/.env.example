# ─── Supabase ─────────────────────────────────────────────────────────────────
# Create a NEW project at supabase.com — keep separate from LeadSmart's DB
NEXT_PUBLIC_HELM_SUPABASE_URL=
NEXT_PUBLIC_HELM_SUPABASE_ANON_KEY=
# Server-only secret — still keyed SMBAI_ for now (rename pending a Vercel env update)
SMBAI_SUPABASE_SERVICE_ROLE_KEY=

# ─── Medical vertical (DoctorSmart AI) — its OWN Supabase project ──────────────
# Public URL + anon key are inlined in next.config.ts; the SERVICE key is the
# only secret. Set it in Vercel env so the host-aware service client (medical
# cron/webhooks/onboarding) can write to the medical project. Without it, those
# paths gracefully fall back to Core.
MEDICAL_SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Price IDs — create in Stripe dashboard
STRIPE_PRICE_ID_STARTER=        # $29/mo
STRIPE_PRICE_ID_GROWTH=         # $79/mo
STRIPE_PRICE_ID_PRO=            # $199/mo

# ─── Plaid ────────────────────────────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox               # sandbox | development | production

# Encrypt Plaid access tokens at rest — generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=             # fallback outbound number, e.g. +15550001234
TWILIO_MESSAGING_SERVICE_SID=  # optional MGxx…; send via the registered Messaging Service for US A2P 10DLC delivery (avoids error 30034)
TWILIO_VALIDATE_WEBHOOK=true

# ─── Retell AI (natural voice calls) ──────────────────────────────────────────
RETELL_API_KEY=
RETELL_FUNCTION_SECRET=         # random secret to verify Retell webhook/function calls
RETELL_AGENT_ID=               # shared receptionist agent bound to provisioned numbers

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@helmsmart.ai
RESEND_INBOUND_WEBHOOK_SECRET=  # optional — verifies inbound webhook from Resend

# Inbound email routing — set to your Resend inbound domain (e.g. inbound.helmsmart.ai)
INBOUND_EMAIL_DOMAIN=

# ─── Google Calendar ──────────────────────────────────────────────────────────
# OAuth app from console.cloud.google.com — scope: calendar.events
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Vercel sets CRON_SECRET automatically — only override for local testing
CRON_SECRET=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3002
