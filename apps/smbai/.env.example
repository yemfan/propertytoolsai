# ─── Supabase ─────────────────────────────────────────────────────────────────
# Create a NEW project at supabase.com — keep separate from LeadSmart's DB
NEXT_PUBLIC_SMBAI_SUPABASE_URL=
NEXT_PUBLIC_SMBAI_SUPABASE_ANON_KEY=
SMBAI_SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Create a NEW Stripe account (or new restricted key) separate from LeadSmart
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Price IDs — create in Stripe dashboard after running pnpm dev once
STRIPE_PRICE_ID_STARTER=        # $29/mo
STRIPE_PRICE_ID_GROWTH=         # $79/mo
STRIPE_PRICE_ID_PRO=            # $199/mo

# ─── Plaid ────────────────────────────────────────────────────────────────────
# Apply at dashboard.plaid.com — sandbox is instant, production needs review (~1-2 wks)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox               # sandbox | development | production

# ─── AI ───────────────────────────────────────────────────────────────────────
# Can reuse the same key as leadsmartai
ANTHROPIC_API_KEY=

# ─── Twilio ───────────────────────────────────────────────────────────────────
# Can reuse the same Twilio account; smbai will provision new numbers per business
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VALIDATE_WEBHOOK=true

# ─── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@smbai.app

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3002
