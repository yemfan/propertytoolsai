# ─── Supabase ─────────────────────────────────────────────────────────────────
# Create a NEW project at supabase.com — keep separate from LeadSmart's DB
NEXT_PUBLIC_SMBAI_SUPABASE_URL=
NEXT_PUBLIC_SMBAI_SUPABASE_ANON_KEY=
SMBAI_SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Price IDs — create in Stripe dashboard
STRIPE_PRICE_ID_STARTER=        # $29/mo
STRIPE_PRICE_ID_GROWTH=         # $79/mo
STRIPE_PRICE_ID_PRO=            # $199/mo

# ─── Plaid ────────────────────────────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox               # sandbox | development | production

# Encrypt Plaid access tokens at rest — generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=             # fallback outbound number, e.g. +15550001234
TWILIO_VALIDATE_WEBHOOK=true

# ─── Retell AI (natural voice calls) ──────────────────────────────────────────
RETELL_API_KEY=
RETELL_FUNCTION_SECRET=         # random secret to verify Retell webhook/function calls

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@helmsmart.ai
RESEND_INBOUND_WEBHOOK_SECRET=  # optional — verifies inbound webhook from Resend

# Inbound email routing — set to your Resend inbound domain (e.g. inbound.helmsmart.ai)
INBOUND_EMAIL_DOMAIN=

# ─── Google Calendar ──────────────────────────────────────────────────────────
# OAuth app from console.cloud.google.com — scope: calendar.events
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Vercel sets CRON_SECRET automatically — only override for local testing
CRON_SECRET=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3002
