{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "corepack": false,
      "node": "20.18.3",
      "ios": {
        "image": "sdk-52"
      },
      "env": {
        "EAS_VERBOSE": "1",
        "EAS_NO_FROZEN_LOCKFILE": "1",
        "NPM_CONFIG_REGISTRY": "https://registry.npmjs.org/",
        "PNPM_CONFIG_CHILD_CONCURRENCY": "1",
        "PNPM_CONFIG_NETWORK_CONCURRENCY": "4"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "extends": "base",
      "distribution": "internal"
    },
    "production": {
      "extends": "base"
    }
  },
  "submit": {
    "production": {}
  }
}
