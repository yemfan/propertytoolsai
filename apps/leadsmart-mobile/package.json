{
  "name": "leadsmart-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "LeadSmart agent mobile app (Expo). Workspace path: apps/leadsmart-mobile.",
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "eas-build-pre-install": "node ./scripts/eas-pre-install.cjs",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "echo skip",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json --noEmit",
    "db:link": "npx supabase link --project-ref babmbowmzwizoahkmshx",
    "db:push": "npx supabase db push",
    "db:migrations:sync": "node ./scripts/sync-migrations-from-leadsmartai.mjs",
    "db:migrations:consolidate": "node ./scripts/build-consolidated-migrations.mjs"
  },
  "dependencies": {
    "@leadsmart/api-client": "workspace:*",
    "@leadsmart/shared": "workspace:*",
    "@supabase/supabase-js": "^2.99.2",
    "expo": "~52.0.35",
    "expo-dev-client": "~5.0.20",
    "expo-constants": "~17.0.5",
    "expo-device": "~7.0.3",
    "expo-notifications": "~0.29.14",
    "expo-secure-store": "~14.0.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo-linking": "~7.0.5",
    "expo-router": "~4.0.17",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-native": "0.76.7",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0"
  },
  "devDependencies": {
    "@expo/metro-config": "0.19.12",
    "@babel/core": "^7.26.0",
    "@types/react": "~18.3.12",
    "babel-plugin-module-resolver": "^5.0.2",
    "typescript": "^5.1.6"
  }
