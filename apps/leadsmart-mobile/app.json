{
  "expo": {
    "name": "LeadSmart",
    "slug": "leadsmart-mobile",
    "scheme": "leadsmart",
    "icon": "./assets/icon.png",
    "version": "1.5.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "platforms": ["ios", "android"],
    "ios": {
      "bundleIdentifier": "ai.leadsmart.mobile",
      "icon": "./assets/icon.png",
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleDisplayName": "LeadSmart",
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": ["tel", "sms", "mailto"],
        "NSPhotoLibraryUsageDescription": "LeadSmart needs access to your photo library to attach images to Quick Post drafts.",
        "NSCameraUsageDescription": "LeadSmart needs access to the camera so you can snap a listing photo for a Quick Post."
      }
    },
    "android": {
      "package": "ai.leadsmart.mobile",
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      }
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      "expo-notifications",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "LeadSmart needs access to your photo library to attach images to Quick Post drafts.",
          "cameraPermission": "LeadSmart needs access to the camera so you can snap a listing photo for a Quick Post."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
