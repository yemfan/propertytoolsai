{
  "expo": {
    "name": "LeadSmart",
    "slug": "leadsmart-mobile",
    "scheme": "leadsmart",
    "icon": "./assets/icon.png",
    "version": "1.3.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "platforms": ["ios", "android"],
    "ios": {
      "bundleIdentifier": "ai.leadsmart.mobile",
      "icon": "./assets/icon.png",
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleDisplayName": "LeadSmart",
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": ["tel", "sms", "mailto"]
      }
    },
    "android": {
      "package": "ai.leadsmart.mobile",
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      }
    },
    "plugins": ["expo-dev-client", "expo-router", "expo-notifications", "expo-apple-authentication"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
