# Base URL for apps/leadsmartai (no trailing slash). Required for mobile API calls.
# You can also use the same names as the Next app (see app.config.ts fallbacks).
EXPO_PUBLIC_LEADSMART_API_URL=
# NEXT_PUBLIC_LEADSMART_API_URL=

# Supabase (same project as LeadSmart web). Expo embeds EXPO_PUBLIC_*; NEXT_PUBLIC_* works via app.config fallbacks.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional dev-only JWT. Prefer signing in via onboarding (token stored in SecureStore).
# EXPO_PUBLIC_LEADSMART_ACCESS_TOKEN=

# EAS / Expo push: project UUID from https://expo.dev — required when not using app.config.ts default.
# EXPO_PUBLIC_EAS_PROJECT_ID=

# Supabase CLI: https://supabase.com/dashboard/account/tokens — for `npm run db:link` / `db:push`
# SUPABASE_ACCESS_TOKEN=
