{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && NEXT_DIST_IN_MONOREPO_ROOT= NEXT_BUILD_OUTPUT_AT_MONOREPO_ROOT= pnpm --filter propertytoolsai run build",
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=12288"
    }
  },
  "crons": [
    {
      "path": "/api/jobs/seo-refresh",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/jobs/seo-expand",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/jobs/seo-optimize",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/seo-content-optimization",
      "schedule": "0 5 * * 0"
    },
    {
      "path": "/api/cron/cluster-generator",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/keyword-discovery",
      "schedule": "0 2 * * 1"
    },
    {
      "path": "/api/cron/lead-score-refresh",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/lead-followups",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/send-emails",
      "schedule": "30 * * * *"
    },
    {
      "path": "/api/cron/tasks-deferred",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/smart-match-daily",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/smart-automation",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/jobs/valuation-calibration",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/city-data-refresh",
      "schedule": "0 5 * * 1"
    },
    {
      "path": "/api/cron/leadsmart-refresh",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/cron/lead-pricing-learning",
      "schedule": "0 2 * * 3"
    }
  ]
}
