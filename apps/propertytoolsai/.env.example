# Copy this file to `.env.local` in this same folder (apps/propertytoolsai).
# `.env.local` is gitignored — it will not appear in git or on other machines until you create it.
#
#   copy .env.example .env.local   (Windows / PowerShell: Copy-Item .env.example .env.local)

# --- Public (exposed to the browser) — required for auth & data ---
# Supabase → Project Settings → API: Project URL + anon (public) key
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional — parent domain for cookies on subdomains (e.g. `.yourdomain.com`). Omit for localhost.
# Sessions are isolated per app by default. To share one login across Property Tools + LeadSmart, also set
# NEXT_PUBLIC_SUPABASE_SHARED_AUTH=true in BOTH apps. See docs/SHARED_AUTH.md (monorepo root).
# NEXT_PUBLIC_AUTH_COOKIE_DOMAIN=.yourdomain.com
# NEXT_PUBLIC_SUPABASE_SHARED_AUTH=true
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Production: set to your canonical live origin (e.g. https://www.propertytoolsai.com) in Vercel so metadata/OG match the deployment.
NEXT_PUBLIC_SITE_URL=http://localhost:3001
# Password reset: add these to Supabase → Authentication → URL configuration → Redirect URLs:
#   http://localhost:3001/reset-password
#   https://<your-production-domain>/reset-password
# Email confirmation / OAuth (signup): also add:
#   http://localhost:3001/auth/callback
#   https://<your-production-domain>/auth/callback

# Optional — LeadSmart AI marketing site for agent/broker cross-sell from the homepage
# NEXT_PUBLIC_LEADSMART_URL=https://leadsmart.ai
# Default assigned agent for PropertyTools consumers (Supabase auth user id = agents.auth_user_id).
# CONSUMER_ASSIGNED_AGENT_AUTH_ID_DEFAULT=
# SMS the agent when a consumer starts an assigned-agent chat (requires Twilio + agent phone on profile).
# AGENT_CHAT_SMS_NOTIFY=true
# Home Value hero / lib/address: Mapbox (Search + Geocoding). Default provider for getAddressProvider().
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
# Optional: mapbox | google — used by getAddressProvider() for programmatic searchAddresses()
NEXT_PUBLIC_ADDRESS_PROVIDER=mapbox
# Optional — other tools still use Google Places when set
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Server-side Geocoding (recommended for /api/address/reverse). Browser-restricted keys fail on Vercel.
# Google Cloud → Credentials → create a server key with Geocoding API enabled (IP restriction ok).
# GOOGLE_MAPS_SERVER_KEY=
# GOOGLE_GEOCODING_API_KEY=

# Paid Stripe checkout: agents, brokers, and listed professional roles are always allowed.
# Set to false to restrict paid plans to professionals only (agents/brokers + agents table).
# ALLOW_CONSUMER_PAID_SUBSCRIPTIONS=true

# --- Server only ---
# Required for /auth/callback OAuth bootstrap (creates user_profiles + app rows if missing).
SUPABASE_SERVICE_ROLE_KEY=
# Bearer token for scheduled jobs (e.g. POST /api/jobs/valuation-calibration with Authorization: Bearer <secret>)
# CRON_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Subscription Price IDs from Stripe → Products → [product] → Pricing (must start with price_, NOT prod_)
STRIPE_PRICE_ID_PRO=
# Consumer Premium ($19/mo) — Price ID for Consumer Premium checkout
STRIPE_PRICE_ID_CONSUMER_PREMIUM=
# Optional — /account/billing “Choose plan” keys (fallback: see lib/billingAccountPriceKeys.ts)
# STRIPE_PRICE_ID_AGENT_STARTER=
# STRIPE_PRICE_ID_AGENT_PRO=
# STRIPE_PRICE_ID_LOAN_BROKER_PRO=

LISTING_FETCH_ENABLED=false

RESEND_API_KEY=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

RENTCAST_API_KEY=
# RENTCAST_BASE_URL=https://api.rentcast.io/v1/markets   # optional override
# RENTCAST_DATA_TYPE=Sale   # Sale | Rental | All (markets endpoint)
# NOMINATIM_USER_AGENT=YourApp/1.0 (contact URL)   # required by OSM for ZIP lookup fallback

OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# Optional: AI-written sections for /tool/[tool]/[location] (cached 7d). Off = fast template copy.
# PROGRAMMATIC_SEO_AI=true

# SEO content optimization weekly batch (GET /api/cron/seo-content-optimization). 0 or unset = skip (no OpenAI).
# SEO_OPT_WEEKLY_LIMIT=50

AGENT_BRAND_NAME=PropertyTools AI
AGENT_NOTIFICATION_EMAIL=

# Optional SMTP (contact form)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
