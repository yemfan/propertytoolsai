{
  "name": "leadsmartai",
  "version": "0.1.0",
  "private": true,
  "description": "LeadSmart CRM, dashboard, AI assistant, automation (Next.js). Workspace path: apps/leadsmartai.",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
