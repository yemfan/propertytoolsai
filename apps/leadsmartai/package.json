    "smoke:leadsmart-ai-layer": "tsx scripts/smoke-leadsmart-ai-layer.ts",
    "smoke:comparison-reports": "tsx scripts/smoke-comparison-reports.ts",
    "smoke:agent-ai-assistant": "tsx scripts/smoke-agent-ai-assistant.ts",
