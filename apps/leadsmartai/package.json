    "@supabase/supabase-js": "^2.99.2",
    "@tailwindcss/postcss": "^4.2.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.1",
    "lightningcss": "1.31.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "nodemailer": "^8.0.2",
    "openai": "^4.104.0",
    "papaparse": "^5.5.3",
    "postcss": "^8.5.8",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-qr-code": "^2.0.18",
