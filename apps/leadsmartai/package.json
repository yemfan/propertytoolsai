    "@types/react": "^18.2.7",
    "autoprefixer": "^10.4.27",
    "dotenv": "^16.4.7",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.0",
    "tsx": "^4.19.3",
    "typescript": "^5.1.6",
    "vitest": "^3.2.4"
  }
