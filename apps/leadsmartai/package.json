    "smoke:growth-engine": "tsx scripts/smoke-growth-engine.ts",
    "smoke:lead-nurturing": "tsx scripts/smoke-lead-nurturing.ts",
    "smoke:lead-marketplace": "tsx scripts/smoke-lead-marketplace.ts",
    "smoke:twilio-sms": "tsx scripts/smoke-twilio-sms.ts",
    "smoke:ai-sms-responder": "tsx scripts/smoke-ai-sms-responder.ts",
    "smoke:sms-conversations-unique": "tsx scripts/smoke-sms-conversations-unique.ts",
    "smoke:traffic-generation": "tsx scripts/smoke-traffic-generation.ts",
