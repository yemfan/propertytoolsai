# Copy to `.env.local` in this folder (apps/leadsmartai).

# --- Required: same Supabase project as Property Tools (one account everywhere) ---
# Dashboard → Project Settings → API: Project URL + anon (public) key
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — parent domain for cookies on subdomains. Sessions are isolated per app by default.
# To share one login with Property Tools, set NEXT_PUBLIC_AUTH_COOKIE_DOMAIN and
# NEXT_PUBLIC_SUPABASE_SHARED_AUTH=true in BOTH apps. See docs/SHARED_AUTH.md (monorepo root).
# NEXT_PUBLIC_AUTH_COOKIE_DOMAIN=.yourdomain.com
# NEXT_PUBLIC_SUPABASE_SHARED_AUTH=true

# Full URL with scheme (required for metadataBase). Host-only values get https:// prepended.
# Password reset: the app builds the email link from NEXT_PUBLIC_SITE_URL (not the browser tab URL), same as OAuth — so production must set this to your public https origin. Add that URL + `/auth/reset-password` under Supabase → Authentication → URL Configuration → Redirect URLs. Flow: `/forgot-password` → email → `/auth/reset-password`.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PropertyToolsAI consumer app origin (no trailing slash). Buyer/seller logins are redirected here instead of LeadSmart.
# Local dev default if unset: http://localhost:3001 — run `pnpm dev:propertytoolsai` from repo root.
# NEXT_PUBLIC_PROPERTYTOOLS_CONSUMER_URL=http://localhost:3001

# Google / Apple sign-in (Supabase OAuth): add these under Authentication → URL Configuration → Redirect URLs
# (production and local), e.g. http://localhost:3000/auth/callback  and  https://<your-domain>/auth/callback
# Enable the providers under Authentication → Providers (Google / Apple).

# Paid checkout: see docs/PAID_SUBSCRIPTIONS_PROFESSIONALS.md (monorepo root).
# ALLOW_CONSUMER_PAID_SUBSCRIPTIONS=true

# Stripe (LeadSmart agent checkout via POST /api/create-checkout-session with cancel_surface: agent)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# Agent Pro (Growth) + Agent Premium (Elite) — recurring monthly Price IDs (price_…)
# STRIPE_PRICE_ID_AGENT_PRO=
# STRIPE_PRICE_ID_AGENT_PREMIUM=
# 14-day trial for agent paid plans (default 14; set to 0 to disable)
# STRIPE_AGENT_TRIAL_DAYS=14

# --- Server only ---
# Required for `/api/support-chat/*`, `/api/me/profile`, `/api/me/avatar`, and `/api/admin/metrics/*` (Founder analytics).
# Profile photos: create a public Storage bucket named `avatars` (Dashboard → Storage). Apply migration adding `user_profiles.avatar_url`.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: other features still use Prisma against Postgres (e.g. repo root DATABASE_URL).
DATABASE_URL=

# Support internal reply API: `Authorization: Bearer <secret>` for POST /api/support/internal/reply
SUPPORT_REPLY_SECRET=

# --- Twilio Voice (inbound AI answering) ---
# Same credentials as SMS; APP_BASE_URL must match the public URL Twilio signs (production).
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VALIDATE_WEBHOOK=true
# APP_BASE_URL=https://your-leadsmart-host.example
#
# Default agent (bigint id from public.agents) for inbound DID when not using VOICE_INBOUND_AGENT_MAP.
# LEADSMART_VOICE_DEFAULT_AGENT_ID=
# Optional JSON map of E.164 To number -> agent id: {"+15551234567":"42"}
# VOICE_INBOUND_AGENT_MAP=
# Optional display number read in fallback TwiML only.
# LEADSMART_VOICE_SUPPORT_DISPLAY=
#
# Media Streams → external WebSocket bridge (OpenAI Realtime, etc.); see docs/TWILIO_VOICE_OPENAI_REALTIME.md
# TWILIO_MEDIA_STREAM_WSS_URL=wss://your-bridge.example/twilio
# TWILIO_MEDIA_STREAM_TRACK=inbound_track
