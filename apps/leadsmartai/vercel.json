{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && NEXT_DIST_IN_MONOREPO_ROOT= NEXT_BUILD_OUTPUT_AT_MONOREPO_ROOT= pnpm --filter leadsmartai run build",
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=12288"
    }
  },
  "crons": [
    {
      "path": "/api/cron/reminder-notification-digest",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/jobs/greetings/run",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/jobs/reengagement/run",
      "schedule": "30 15 * * *"
    },
    {
      "path": "/api/cron/ai-followups",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/lead-followups",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/cron/send-emails",
      "schedule": "45 * * * *"
    },
    {
      "path": "/api/cron/smart-automation",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/lead-score-refresh",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/tasks-deferred",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/lead-pricing-learning",
      "schedule": "0 2 * * 3"
    },
    {
      "path": "/api/cron/city-data-refresh",
      "schedule": "0 5 * * 1"
    },
    {
      "path": "/api/cron/leadsmart-refresh",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/marketing-plans",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/sphere-drafts-sender",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/sphere-scheduler",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/transactions-overdue-nudges",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/transactions-wire-fraud-alert",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/growth-weekly-digest",
      "schedule": "0 16 * * 1"
    }
  ]
}
