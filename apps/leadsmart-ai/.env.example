# Copy to `.env.local` in this folder (apps/leadsmart-ai).

# --- Must match Property Tools (same Supabase project = one account everywhere) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — share session cookies with Property Tools on subdomains (production)
# NEXT_PUBLIC_AUTH_COOKIE_DOMAIN=.yourdomain.com
# See docs/SHARED_AUTH.md in the monorepo root.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Paid checkout: see docs/PAID_SUBSCRIPTIONS_PROFESSIONALS.md (monorepo root).
# ALLOW_CONSUMER_PAID_SUBSCRIPTIONS=true

# --- Server only ---
SUPABASE_SERVICE_ROLE_KEY=
