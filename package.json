{
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:property-tools": "npm run dev -w property-tools -- --port 3001",
    "dev:leadsmart": "npm run dev -w leadsmart-ai -- --port 3000",
    "clean:next": "node -e \"const fs=require('fs');const path=require('path');for(const app of ['leadsmart-ai','property-tools']){const p=path.join('apps',app,'.next');try{fs.rmSync(p,{recursive:true,force:true});console.log('cleaned',p);}catch(e){console.warn('skip',p,e?.message||e);}}\"",
    "build": "npm run clean:next && turbo build --concurrency=1",
    "lint": "turbo lint",
    "smoke:db:all": "node scripts/smoke-db-all.mjs"
  },
  "devDependencies": {
    "turbo": "^2.8.20"
  }
}
