{
  "private": true,
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:property-tools": "npm run dev -w property-tools -- --port 3001",
    "dev:leadsmart": "npm run dev -w leadsmart-ai -- --port 3000",
    "clean:next": "node -e \"const fs=require('fs');const path=require('path');for(const app of ['leadsmart-ai','property-tools']){const p=path.join('apps',app,'.next');try{fs.rmSync(p,{recursive:true,force:true});console.log('cleaned',p);}catch(e){console.warn('skip',p,e?.message||e);}}\"",
    "build": "node scripts/vercel-monorepo-root-build.mjs",
    "build:leadsmart": "cross-env NODE_OPTIONS=--max-old-space-size=12288 npm run build -w leadsmart-ai",
    "build:property-tools": "cross-env NODE_OPTIONS=--max-old-space-size=12288 npm run build -w property-tools",
    "build:vercel-leadsmart-root": "cross-env NODE_OPTIONS=--max-old-space-size=12288 npm run build -w leadsmart-ai",
    "build:vercel-property-tools-root": "cross-env NODE_OPTIONS=--max-old-space-size=12288 npm run build -w property-tools",
    "lint": "turbo lint",
    "smoke:db:all": "node scripts/smoke-db-all.mjs"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "turbo": "^2.8.20"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.1",
    "@tailwindcss/oxide-linux-x64-musl": "4.2.1",
    "lightningcss-linux-x64-gnu": "1.31.1",
    "lightningcss-linux-x64-musl": "1.31.1"
  },
  "dependencies": {
    "lucide-react": "^0.577.0"
  }
}
