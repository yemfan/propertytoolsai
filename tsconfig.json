{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "apps/leadsmart-ai/*",
        "apps/property-tools/*"
      ],
      "@repo/ui": ["packages/ui/navigation/index.ts"],
      "@repo/tools": ["packages/tools/src"],
      "@repo/ai": ["packages/ai/src"],
      "@repo/lib": ["packages/lib/src"],
      "@repo/types": ["packages/types/src"]
    }
  },
  "exclude": ["node_modules", "**/.next"]
}

