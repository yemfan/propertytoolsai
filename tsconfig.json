{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "noEmit": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/leadsmartai/*", "apps/propertytoolsai/*"],
      "@repo/ui": ["packages/ui/navigation/index.ts"],
      "@repo/tools": ["packages/tools/src"],
      "@repo/ai": ["packages/ai/src"],
      "@repo/lib": ["packages/lib/src"],
      "@repo/types": ["packages/types/src"],
      "@leadsmart/shared": ["packages/shared/src/index.ts"],
      "@leadsmart/shared/*": ["packages/shared/src/*"],
      "@leadsmart/api-client": ["packages/api-client/src/index.ts"],
      "@leadsmart/api-client/*": ["packages/api-client/src/*"]
    }
  },
  "exclude": ["node_modules", "**/.next", "apps/leadsmart-mobile"]
}
